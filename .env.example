# Copy to .env and adjust as needed. All values have sane defaults; the system
# runs with NO .env file at all.

# --- Storage ---------------------------------------------------------------
# SQLite for local dev. Swap to Postgres with a single line, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/freight
DATABASE_URL=sqlite:///./logistics.db

# Durable LangGraph checkpoint store (powers interrupt/resume across restarts).
CHECKPOINT_DB=./agent_checkpoints.db

# Reference + test data the loader ingests.
SEED_DATA_PATH=./seed_data.json

# --- Business tolerances ---------------------------------------------------
CHARGE_MATCH_TOLERANCE=0.01
CHARGE_DISPUTE_THRESHOLD=0.25
WEIGHT_MATCH_TOLERANCE_KG=1.0
GST_RATE=0.18

# --- Decision thresholds ---------------------------------------------------
AUTO_APPROVE_MIN_CONFIDENCE=0.85
HUMAN_REVIEW_MAX_CONFIDENCE=0.60

# --- Optional LLM (system works fully without this) ------------------------
# Used ONLY for carrier-name normalisation and explanation text — never for
# money or decisions. Leave unset to use deterministic fallbacks.
LLM_ENABLED=false
# ANTHROPIC_API_KEY=sk-ant-...
